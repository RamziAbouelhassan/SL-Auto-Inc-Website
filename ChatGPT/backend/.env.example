HOST=0.0.0.0
PORT=3000
NODE_ENV=development

# Frontend URL when you deploy (example: https://slautoinc.ca)
# Leave empty during local dev to allow all origins.
CORS_ORIGIN=

# Local demo mode:
# - Leave BOOKING_STORAGE empty to auto-select file storage locally.
# - Use BOOKING_STORAGE=supabase to force Supabase locally too.
# - Netlify production should use Supabase, not a local file.
BOOKING_STORAGE=

# Where booking requests are stored in local demo mode.
BOOKINGS_FILE=./data/bookings.jsonl

# Supabase production storage for Netlify Functions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE=bookings
